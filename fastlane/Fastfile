# ── Echo: Audiobook Study Player Fastlane Configuration ────────────────────────

default_platform(:ios)

# ── Helpers ────────────────────────────────────────────────────────

# Returns true if the given scheme name exists in the project.
def scheme_exists?(scheme_name)
  output = sh(
    "xcodebuild -project 'Echo.xcodeproj' -list -json",
    log: false
  )
  JSON.parse(output)["project"]["schemes"].include?(scheme_name)
rescue
  false
end

def release_archive_xcargs(build_number)
  "CURRENT_PROJECT_VERSION=#{build_number} -jobs 5"
end

def github_warning(message)
  UI.important(message)
  puts("::warning::#{message}") if ENV["GITHUB_ACTIONS"] == "true"
  summary_path = ENV["GITHUB_STEP_SUMMARY"]
  return if summary_path.to_s.empty?

  File.open(summary_path, "a") do |file|
    file.puts("### Warning")
    file.puts(message)
    file.puts
  end
end

# ── Platforms & Lanes ──────────────────────────────────────────────

platform :ios do
  
  before_all do
    # Load the App Store Connect API key from your local git-ignored JSON file.
    # On CI, ensure these variables are mapped via env vars.
    #
    # Guarded so key-free lanes (screenshots, frame_screenshots) still run when
    # fastlane/api_key.json is absent. Lanes that talk to App Store Connect
    # (beta, upload_screenshots) check `@api_key` and fail with a clear message.
    require 'json'
    key_path = "api_key.json"
    if File.exist?(key_path)
      key_data = JSON.parse(File.read(key_path))
      @api_key = app_store_connect_api_key(
        key_id: key_data["key_id"],
        issuer_id: key_data["issuer_id"],
        key_content: key_data["key"],
        in_house: key_data["in_house"]
      )
    else
      @api_key = nil
      UI.important("No fastlane/api_key.json found — App Store Connect lanes are unavailable. Screenshot capture lanes work without it.")
    end
  end

  # Fails fast on lanes that require App Store Connect when no key is configured.
  def require_api_key!
    UI.user_error!(
      "This lane needs App Store Connect access. Create fastlane/api_key.json " \
      "(see fastlane/README.md / Appfile) and re-run."
    ) if @api_key.nil?
  end

  desc <<~DESC
    Archive and upload to TestFlight.

    This lane:
    1. Syncs code signing via match (appstore) for all bundle IDs
    2. Archives the iOS target (includes bundled watchOS app + widget)
    3. Archives the macOS target (if a macOS scheme exists)
    4. Uploads all resulting .ipa / .pkg files to TestFlight

    Prerequisites:
    - fastlane match set up with a git repo and MATCH_PASSWORD
    - App Store Connect API key JSON at fastlane/api_key.json
  DESC
  lane :beta do |options|
    require_api_key!

    # ── CI: non-interactive code-signing keychain ─────────────────────
    # Create a dedicated temporary keychain with its partition list set so
    # codesign can use the match-installed signing key WITHOUT a GUI prompt.
    # Without this, the archive's *signing* step hangs forever on a headless
    # runner waiting for a keychain-access dialog that no one can click (the
    # multi-hour stall at "Signing …appex"). No-op locally — local dev signs
    # against the login keychain. Must run BEFORE match so it installs there.
    setup_ci if is_ci

    # ── Release-train channel → TestFlight group routing ──────────────
    # release-trains.yml passes channel:nightly|weekly. Map each channel to its
    # tester group + distribution mode:
    #   nightly → "Nightly" (INTERNAL group: builds available instantly, no review)
    #   weekly  → "Weekly"  (EXTERNAL group: first build of a version needs Beta App Review)
    # Unknown/absent channel (e.g. a manual `fastlane beta`) → no group targeting.
    channel = (options[:channel] || ENV["RELEASE_CHANNEL"] || "").to_s.downcase
    tf_group, tf_external = case channel
                            when "nightly" then ["Nightly", false]
                            when "weekly"  then ["Weekly", true]
                            else [nil, false]
                            end
    UI.message("Release channel: #{channel.empty? ? '(none)' : channel} → group: #{tf_group || '(none)'}, external: #{tf_external}")

    # ── Nightly only: auto-draft "What to Test" from the commit delta ──────
    # Internal/nightly testers should always see fresh copy. Weekly/external
    # builds intentionally skip this and ship the human-curated committed file.
    # Fail-safe: the generator leaves the committed file untouched on empty
    # delta or any error, so this can never break a build.
    if channel == "nightly"
      UI.message("Nightly channel → regenerating testflight/what_to_test.txt from commit delta")
      sh(
        "cd .. && git fetch --no-tags --quiet origin weekly:refs/remotes/origin/weekly || true && " \
        "PYTHONPATH=Scripts python3 -m doc_automation.whats_new " \
        "--template fastlane/testflight/what_to_test.template.txt " \
        "--out fastlane/testflight/what_to_test.txt"
      )
    end

    # ── Build number (computed once; used by both iOS and macOS archives) ──
    # TestFlight requires each upload's build number (CFBundleVersion) to be
    # unique and higher than the previous. MARKETING_VERSION is left alone —
    # bump that only for real releases. Query TestFlight's latest build and add
    # one (starts at 1 when the app has no builds). Applied via xcargs so
    # CURRENT_PROJECT_VERSION is overridden without mutating the project.
    next_build = latest_testflight_build_number(
      api_key: @api_key,
      app_identifier: "com.echo.audiobooks",
      initial_build_number: 0
    ) + 1
    UI.message("Build number for this run: #{next_build}")

    # ── iOS: sync → (CI) manual-sign → archive ────────────────────────────
    # IMPORTANT: iOS is signed *and archived* fully BEFORE the macOS sync. The
    # macOS app is universal — it shares the iOS bundle id (com.echo.audiobooks)
    # under the `macos` platform — so its Mac App Store profile would overwrite
    # the iOS profile in match's bundle-id-keyed MATCH_PROVISIONING_PROFILE_MAPPING.
    # Building iOS first keeps the live mapping correct for the iOS archive/export.
    # (On CI the project's Automatic signing can't mint profiles headlessly, so we
    # switch each target to the match profile manually; local dev keeps Automatic.)
    sync_code_signing(
      api_key: @api_key,
      type: "appstore",
      app_identifier: [
        "com.echo.audiobooks",                   # main iOS app
        "com.echo.audiobooks.watchkitapp",         # bundled watchOS app
        "com.echo.audiobooks.watchkitapp.widget"   # widget extension
      ],
      readonly: is_ci
    )
    if is_ci
      mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}
      {
        "Echo"                 => "com.echo.audiobooks",
        "Echo Watch App"       => "com.echo.audiobooks.watchkitapp",
        "Echo WidgetExtension" => "com.echo.audiobooks.watchkitapp.widget"
      }.each do |target, bundle_id|
        profile = mapping[bundle_id]
        next if profile.nil?
        update_code_signing_settings(
          path: "Echo.xcodeproj",
          use_automatic_signing: false,
          targets: [target],
          team_id: "8AXNA5B37R",
          code_sign_identity: "Apple Distribution",
          profile_name: profile
        )
      end
    end
    build_app(
      project: "Echo.xcodeproj",
      scheme: "Echo",
      export_method: "app-store",
      output_directory: "build",
      xcargs: release_archive_xcargs(next_build)
    )

    # ── macOS: sync → (CI) manual-sign → archive ──────────────────────────
    # Universal app: the Mac App Store profile is under the SAME bundle id
    # (com.echo.audiobooks) but the `macos` platform. Synced AFTER the iOS build
    # so it doesn't clobber the iOS profile mapping. Nightly may continue after a
    # visible warning; weekly/release lanes fail so Mac archive regressions cannot
    # silently ride the promotion train.
    if scheme_exists?("Echo macOS")
      begin
        sync_code_signing(
          api_key: @api_key,
          type: "appstore",
          platform: "macos",
          app_identifier: ["com.echo.audiobooks"],
          readonly: is_ci
        )
        if is_ci
          macos_profile = (lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {})["com.echo.audiobooks"]
          unless macos_profile.nil?
            update_code_signing_settings(
              path: "Echo.xcodeproj",
              use_automatic_signing: false,
              targets: ["Echo macOS"],
              team_id: "8AXNA5B37R",
              code_sign_identity: "Apple Distribution",
              profile_name: macos_profile
            )
          end
        end
        build_app(
          project: "Echo.xcodeproj",
          scheme: "Echo macOS",
          export_method: "app-store",
          output_directory: "build",
          xcargs: release_archive_xcargs(next_build)
        )
      rescue => e
        message = "macOS archive failed for #{channel.empty? ? 'manual' : channel} channel: #{e.message}"
        if channel == "nightly"
          github_warning("#{message}. Continuing nightly iOS upload; fix the macOS target and re-run.")
        else
          UI.user_error!("#{message}. Weekly/release trains require a successful macOS archive.")
        end
      end
    else
      UI.important("No macOS scheme found — skipping macOS build. Create 'Echo macOS' scheme in Xcode to include it.")
    end

    # ── Upload to TestFlight ─────────────────────────
    # This will automatically pick up and upload both the iOS (.ipa) and macOS (.pkg/.ipa) binaries found in the build directory
    # TestFlight copy lives in version-controlled files (paths relative to fastlane/):
    #   testflight/what_to_test.txt          → per-build "What to Test" (≤4000 chars)
    #   testflight/beta_app_description.txt  → Test Information description (≤4000 chars)
    tf_options = {
      api_key: @api_key,
      # pilot needs a single bundle id; the Appfile's for_lane(:beta) sets
      # app_identifier to an ARRAY (for match), which upload_to_testflight rejects.
      app_identifier: "com.echo.audiobooks",
      skip_waiting_for_build_processing: false,
      notify_external_testers: tf_external,
      changelog: File.read("testflight/what_to_test.txt"),
      beta_app_description: File.read("testflight/beta_app_description.txt"),
      # Where TestFlight's "Send Beta Feedback" emails land. Reuses the App Store
      # review contact for now; swap for a dedicated support address if one exists.
      beta_app_feedback_email: File.read("metadata/review_information/email_address.txt").strip
    }
    # Only EXTERNAL channels need explicit group distribution. Internal testers
    # (the Nightly group) AUTOMATICALLY receive every processed (VALID) build — no
    # distribution call needed. Worse, pilot's distribute_build treats any `groups`
    # assignment as an external submission and demands full Beta App Review data
    # (demo account, contact, notes), so passing the internal group makes the lane
    # fail with "Missing required information to submit for external testing". The
    # external Weekly group genuinely submits for review, so it keeps the groups +
    # distribute_external path.
    if tf_group && tf_external
      tf_options[:groups] = [tf_group]
      tf_options[:distribute_external] = true
    end
    upload_to_testflight(tf_options)
  end

  lane :test_auth do
    require_api_key!
    # API key is already loaded in before_all, but we can verify it
    UI.success("API Key loaded successfully!")
  end

  desc <<~DESC
    Capture App Store screenshots on the simulator.

    Runs the EchoScreenshots UI test (EchoUITests target) via the
    "Echo Screenshots" scheme across the devices/languages in fastlane/Snapfile,
    writing PNGs to fastlane/screenshots/<locale>/.

    No App Store Connect key required.

    Prerequisites:
    - The app auto-seeds a sample audiobook in DEBUG simulator builds, but ONLY
      if `BIFF.m4b` is bundled into the Echo app target. Without it the library
      is empty and content-gated screens (Reader/Timeline) show empty states.
      See fastlane/screenshots/en-US/README_SCREENSHOTS.md.
    - Device names in Snapfile must match `xcrun simctl list devices`.

    Tip: stage the trickier shots by hand with Scripts/capture_screenshots.sh.
  DESC
  lane :screenshots do
    capture_screenshots
    UI.success("Screenshots written to fastlane/screenshots/. Review them, then run `fastlane upload_screenshots`.")
  end

  desc "Wrap the captured screenshots in device frames (requires `brew install imagemagick`)."
  lane :frame_screenshots do
    frameit(path: "./fastlane/screenshots")
  end

  desc <<~DESC
    Upload screenshots + metadata to App Store Connect (no binary).

    Pushes fastlane/screenshots/ and fastlane/metadata/ to the app's current
    editable version. Requires fastlane/api_key.json.
  DESC
  lane :upload_screenshots do
    require_api_key!
    upload_to_app_store(
      api_key: @api_key,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true # skip the HTML preview/confirmation prompt
    )
  end
end
