# ── Echo: fastlane snapshot configuration ──────────────────────────────────────
# Captures App Store screenshots by running the EchoScreenshots UI test on each
# device below. Invoke via `bundle exec fastlane screenshots` (see Fastfile).
# Docs: https://docs.fastlane.tools/actions/snapshot/

# Apple now requires only the 6.9" iPhone and the 13" iPad for new submissions;
# every smaller size is derived from those. Add more lines if you want native
# captures at other sizes — but keep the list short on a 16 GB machine.
#
require "json"

def available_simulator_names
  JSON.parse(`xcrun simctl list devices available --json`)
    .fetch("devices")
    .values
    .flatten
    .select { |device| device["isAvailable"] }
    .map { |device| device.fetch("name") }
end

def first_available_device(*preferred_names, matching: nil)
  available = available_simulator_names
  preferred_names.find { |name| available.include?(name) } ||
    available.find { |name| matching && name.match?(matching) } ||
    preferred_names.first
end

devices([
  first_available_device(
    "iPhone 17 Pro Max",
    matching: /^iPhone .* Pro Max$/
  ), # 6.9" iPhone class (required)
  first_available_device(
    "iPad Pro 13-inch (M5)",
    matching: /^iPad Pro 13-inch/
  ) # 13" iPad class (required)
])

languages([
  "en-US"
])

# The dedicated scheme whose Test action runs EchoUITests (the default Echo
# scheme intentionally excludes UI tests).
scheme("Echo Screenshots")

# Run ONLY the screenshot test, not the boilerplate EchoCoreUITests.
only_testing(["EchoUITests/EchoScreenshots"])

# EchoScreenshots asserts that each automated device captures these categories:
# 01_Player, 02_Timeline, 03_Reader, 04_Stats, 05_Settings.

# Where the PNGs land (picked up as-is by deliver / upload_to_app_store).
output_directory("./fastlane/screenshots")

# Wipe previous captures so renamed/removed shots don't linger.
clear_previous_screenshots(true)

# Clean status bar in every shot: 9:41, full bars, 100% battery, no carrier text.
override_status_bar(true)

# Keep App Store screenshots in Echo's dark, cover-tonal presentation.
dark_mode(true)

# RAM-friendly on a 16 GB machine: never boot simulators in parallel.
# (CLAUDE.md: never run xcodebuild with parallel testing enabled.)
concurrent_simulators(false)

# Build once, reuse the product across devices/languages.
reinstall_app(true)
erase_simulator(false)

# Open the HTML summary when finished (set to false on CI).
