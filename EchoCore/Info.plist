<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.echo.audiobooks.echo</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>echoaudio</string>
			</array>
		</dict>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Echo connects to user-provided, self-hosted Audiobookshelf servers (LAN,
		     Tailscale/CGNAT 100.64.0.0/10, VPN, reverse proxies) the developer does not
		     control and that commonly run over plaintext HTTP. NSAllowsLocalNetworking is
		     insufficient: the Tailscale shared range is not an ATS "local" range. -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Echo remembers where you listen so you can revisit the context. Location is opt-in, reduced accuracy, on-device only, and deletable at any time.</string>
	<key>NSLocationDefaultAccuracyReduced</key>
	<true/>
	<key>NSMicrophoneUsageDescription</key>
	<string>Echo records short voice memos so you can attach narrated notes to your audiobook bookmarks.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Echo allows you to save EPUB images directly to your photo library.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Echo lets you dictate short text notes for audiobook bookmarks.</string>
	<key>UIAppFonts</key>
	<array>
		<string>Lexend.ttf</string>
		<string>OpenDyslexic-Regular.otf</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
</dict>
</plist>
